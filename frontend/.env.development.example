# Local Vite development — copy pieces into `.env.development.local` if you need overrides.
# Do not commit `.env*.local` (gitignored).
#
# The browser must call same-origin `/api` (and `/iot` for the player API). Never set
# VITE_API_BASE_URL=https://backend:8000/api — the hostname `backend` only resolves
# inside Docker networks; the browser will fail with ERR_NAME_NOT_RESOLVED.
#
# docker-compose.yml sets VITE_API_BASE_URL=/api and VITE_PROXY_TARGET=http://backend:8000
# for the `frontend` service. For `npm run dev` on the host with Django on localhost:8000,
# use the proxy target below (Vite reads this; it is not exposed to the browser bundle).

VITE_API_BASE_URL=/api
VITE_IOT_BASE_URL=/iot
# Optional: CodeCanyon product URL for Landing “View on CodeCanyon”
# VITE_CODECANYON_ITEM_URL=

# Vite dev server only: where Node proxies /api, /ws, /media, /iot, /public-iot
# Host + Django on 127.0.0.1:8000:
# VITE_PROXY_TARGET=http://127.0.0.1:8000
# Frontend dev container (default in docker-compose): set by Compose, not usually needed here:
# VITE_PROXY_TARGET=http://backend:8000
