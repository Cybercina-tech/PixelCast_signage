# Django Settings
# Template/reference only.
# Docker Compose reads `.env` (required) and does not load `.env.example`.
SECRET_KEY=asdflsajdkf324k2345sdfjbgasdfndjfhjl42j34ejrb2l45b2j35b2l3j5b2j35b2l3kj5b3j
DEBUG=False
# Local docker-compose.yml defaults BOOTSTRAP_DEFAULT_ADMIN=true so admin@pixelcast.com / adminadmin exists on first boot.
# Production: keep false (docker-compose.prod.yml sets false). Reset password: python manage.py ensure_default_developer --update
# BOOTSTRAP_DEFAULT_ADMIN=false
# Include .traefik.me (leading dot = subdomains) for Dokploy preview URLs; add your real domain in production.
# With DEBUG=True, localhost / 127.0.0.1 / backend / frontend are merged in settings (Vite proxy + Docker).
ALLOWED_HOSTS=www.pixelcast.cybercina.co.uk,pixelcast.cybercina.co.uk
CSRF_TRUSTED_ORIGINS=https://pixelcast.cybercina.co.uk,https://www.pixelcast.cybercina.co.uk
# Extra allowed CORS origins (comma-separated); merged with localhost/Vite defaults in settings.
# CORS_ALLOWED_ORIGINS=https://pixelcast.cybercina.co.uk,https://www.pixelcast.cybercina.co.uk
# TLS: SECURE_SSL_REDIRECT defaults on when BASE_URL is https. Set SECURE_SSL_REDIRECT=false for plain HTTP.
# SESSION_COOKIE_SECURE / CSRF_COOKIE_SECURE follow SECURE_SSL_REDIRECT unless set explicitly.
# SECURE_HSTS_SECONDS=31536000
# USE_BEHIND_PROXY=True
# Optional: override built-in notification/SMTP-at-rest Fernet key (default is derived in app; unset is fine)
# NOTIFICATION_ENCRYPTION_KEY=

# Database Configuration (single source for Docker Compose)
# Django uses DB_* . The official Postgres image reads POSTGRES_* — keep the same values as DB_* below.
DB_NAME=pixelcast_signage_db
DB_USER=pixelcast_signage_user
DB_PASSWORD=safpewri234aca
DB_HOST=db
DB_PORT=5432
USE_SQLITE=False
# Postgres container (docker-compose env_file) — must match DB_NAME / DB_USER / DB_PASSWORD above
POSTGRES_DB=pixelcast_signage_db
POSTGRES_USER=pixelcast_signage_user
POSTGRES_PASSWORD=safpewri234aca

# Application URLs
BASE_URL=https://pixelcast.cybercina.co.uk

# Optional: protects GET /api/core/deploy/status/ (deploy log tail). Send header X-Deployment-Status-Secret with the same value. Leave empty to keep the endpoint disabled.
# DEPLOYMENT_STATUS_SECRET=

# Android TV player APK URL (optional). Exposed at GET /api/public/downloads/ for the Data Center download button.
# Prefer this over Vite build-time VITE_ANDROID_TV_APK_URL so you can change the link without rebuilding the frontend.
ANDROID_TV_APK_URL=


# Weather Widget (OpenWeather)
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org
WEATHER_REFRESH_INTERVAL_SECONDS=900
WEATHER_STALE_TTL_SECONDS=21600
WEATHER_HTTP_TIMEOUT_SECONDS=5
WEATHER_FORECAST_DAYS=5

# License Configuration
# Self-hosted: set LICENSE_GATEWAY_BASE_URL to the operator SaaS base, e.g.
#   https://your-cloud.example.com/api/license-registry/v1
# (activate + heartbeat + optional ticket mirror …/tickets/ingest/). Validation uses that base + /validate/ when set; otherwise LICENSE_SERVER_URL.
LICENSE_GATEWAY_BASE_URL=
LICENSE_SERVER_URL=
# CODECANYON_TOKEN: required on the operator SaaS (license gateway) only; leave empty on self-hosted.
CODECANYON_TOKEN=
# Envato item ID(s) — comma-separated allowed item IDs on the gateway; same on self-hosted for product checks
CODECANYON_PRODUCT_ID=
# Optional: map item IDs to Self-Hosted Basic vs SaaS (gateway). If both lists are empty, all allowed IDs use default.
CODECANYON_BASIC_ITEM_IDS=
CODECANYON_SAAS_ITEM_IDS=
CODECANYON_DEFAULT_SELF_HOSTED_PLAN_TYPE=saas
LICENSE_ENFORCEMENT_ENABLED=True
# Stale gateway contact (self-hosted): warn → read-only API → Developer-only API (days without successful validate/heartbeat)
LICENSE_STALE_CONTACT_ENFORCEMENT_ENABLED=True
LICENSE_STALE_CONTACT_WARN_DAYS=7
LICENSE_STALE_CONTACT_READONLY_DAYS=14
LICENSE_OFFLINE_GRACE_HOURS=72
LICENSE_CACHE_TTL_SECONDS=900
LICENSE_SERVER_TIMEOUT_SECONDS=8
# Optional app version string sent with license heartbeats / activation
SCREENGRAM_APP_VERSION=
# SaaS license registry API (/api/license-registry/v1/*). Off only for special cases.
LICENSE_REGISTRY_API_ENABLED=True
# If >0, gateway validate-by-token fails when last heartbeat is older than this many hours (0 = disabled)
LICENSE_REGISTRY_HEARTBEAT_MAX_AGE_HOURS=0
# Super-admin UI: mark row inactive after no heartbeat for this many hours
LICENSE_REGISTRY_INACTIVE_AFTER_HOURS=72
# Operator SaaS: rate limit for POST …/license-registry/v1/tickets/ingest/ (self-hosted ticket mirror)
LICENSE_REGISTRY_TICKET_INGEST_RATE_PER_MINUTE=30

# Deployment: saas | self_hosted | hybrid — hybrid uses PLATFORM_SAAS_ENABLED below.
DEPLOYMENT_MODE=hybrid
# Self-hosted only: mirror new tickets and customer replies to the operator (requires LICENSE_GATEWAY_BASE_URL + activation)
TICKET_OPERATOR_BRIDGE_ENABLED=False
# Platform SaaS (multi-tenant super-admin UI, Stripe webhooks). Ignored when DEPLOYMENT_MODE=self_hosted; forced on when saas.
PLATFORM_SAAS_ENABLED=True
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe subscription price ID for legacy Checkout only (when POST body omits plan_key).
# Per-plan Price IDs are stored in the database (Super Admin → Pricing catalog).
STRIPE_PRICE_ID=
STRIPE_GRACE_PERIOD_DAYS=7
# Public SPA URL for emails and password reset links
PUBLIC_WEB_APP_URL=http://localhost:5173
# Enterprise SSO placeholder
SSO_ENABLED=False

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
USE_REDIS_CACHE=True
REDIS_CACHE_URL=redis://redis:6379/1

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Channel Layers (Django Channels)
CHANNEL_LAYERS_BACKEND=redis

# Port Mappings (for docker-compose)
BACKEND_PORT=8000
# Dev (docker-compose.yml): host port published to Vite :5173 — use FRONTEND_HOST_PORT (avoid FRONTEND_PORT; some hosts set it to 80 and break Traefik)
FRONTEND_HOST_PORT=5173
HTTP_PORT=8080
# Prod (docker-compose.prod.yml): host port is pinned to 8080 in compose.
# Vite dev behind HTTPS (Traefik/Dokploy): 1 = wss on :443 (fixes Mixed Content). Local http → 0.
VITE_BEHIND_HTTPS_PROXY=0
# Optional: direct APK URL at build time (Data Center). Server-side ANDROID_TV_APK_URL overrides when unset in Vite.
# VITE_ANDROID_TV_APK_URL=
# Optional overrides (usually not needed if VITE_BEHIND_HTTPS_PROXY=1)
# VITE_HMR_PROTOCOL=wss
# VITE_HMR_CLIENT_PORT=443
# Frontend WebSocket base (origin only, e.g. wss://app.example.com). Omit in dev: same origin as the Vite app so /ws proxies to Django.
# VITE_WS_URL=
#
# API base baked into the SPA at Vite build / dev start. MUST be a relative path (/api) or a real public URL.
# NEVER set VITE_API_BASE_URL=https://backend:8000/api (or http://backend:...) — the browser cannot resolve
# the hostname "backend" (ERR_NAME_NOT_RESOLVED). docker-compose.yml sets VITE_API_BASE_URL=/api for the
# frontend service; Vite proxies /api to Django via VITE_PROXY_TARGET inside the container.
# VITE_API_BASE_URL=/api
#
# Production (`docker-compose -f docker-compose.prod.yml`): the frontend image sets VITE_API_BASE_URL=/api and
# VITE_IOT_BASE_URL=/iot in frontend/Dockerfile + compose build args. Nginx serves the SPA and proxies /api to
# Django (frontend/nginx.conf). You normally do NOT put VITE_* in root .env for prod — rebuild the frontend
# image after changing API public URL: `docker compose -f docker-compose.prod.yml build --no-cache frontend`

# --- Frontend (Vite) — SEO & analytics (baked in at build; set in CI/env for production images) ---
# Canonical URLs, Open Graph, JSON-LD, and sitemap/robots.txt generation (vite build).
# Use your public site origin with scheme, no trailing slash (e.g. https://www.example.com).
# VITE_PUBLIC_SITE_ORIGIN=https://pixelcast.cybercina.co.uk
# Soft local/region hint for copy & Organization schema (e.g. UK enables areaServed GB). Optional.
# VITE_PUBLIC_REGION=UK
# Default social share image (full HTTPS URL, 1200×630). Optional; omit until asset exists.
# VITE_OG_IMAGE_URL=https://pixelcast.cybercina.co.uk/og-default.png
# Google Tag Manager — set to enable container (GTM-XXXX). Leave unset for no third-party tags.
# VITE_GTM_CONTAINER_ID=GTM-XXXXXXX
# Optional: only if not loading GA4 via GTM (avoid duplicate GA4).
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
#
# Landing page: full URL to the CodeCanyon item (optional; button disabled if empty)
# VITE_CODECANYON_ITEM_URL=https://codecanyon.net/item/...
# Google Ads (documented for GTM; not loaded by app directly unless you add a tag).
# GOOGLE_ADS_ID=AW-XXXXXXXXX
# GOOGLE_ADS_CONVERSION_LABEL=xxxxxxxxxx

# Optional: AWS S3 Configuration (if using S3 storage)
# USE_S3_STORAGE=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=pixelcast-signage-content
# AWS_S3_REGION_NAME=us-east-1

# Optional: Email Configuration
# Prefer Core Infrastructure → Email / SMTP in the admin UI (Developer). These vars are used as
# fallback when the DB is not configured or delivery mode does not use panel SMTP.
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=no-reply@pixelcastsignage.com

# Optional: Notification Encryption Key (also used to encrypt stored SMTP password in system email settings)
# NOTIFICATION_ENCRYPTION_KEY=

# Optional: Backup Configuration
# BACKUP_DIR=/app/backups
# BACKUP_RETENTION_DAYS=30
# ENABLE_AUTO_BACKUP=False
# BACKUP_ENCRYPTION=False

# Optional: Rate Limiting
# RATE_LIMITING_ENABLED=True
# MAX_LOGIN_ATTEMPTS=5
# LOCKOUT_DURATION=900

# Optional: Audit Logging
# AUDIT_LOGGING_ENABLED=True
# AUDIT_LOG_READS=False
# AUDIT_RETENTION_DAYS=365

