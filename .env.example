# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
# Include .traefik.me (leading dot = subdomains) for Dokploy preview URLs; add your real domain in production.
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend,.traefik.me

# Database Configuration
DB_NAME=pixelcast_signage_db
DB_USER=pixelcast_signage_user
DB_PASSWORD=your-secure-password-here
DB_HOST=db
DB_PORT=5432
USE_SQLITE=False

# Application URLs
BASE_URL=http://localhost:8000

# Weather Widget (OpenWeather)
OPENWEATHER_API_KEY=
OPENWEATHER_BASE_URL=https://api.openweathermap.org
WEATHER_REFRESH_INTERVAL_SECONDS=900
WEATHER_STALE_TTL_SECONDS=21600
WEATHER_HTTP_TIMEOUT_SECONDS=5
WEATHER_FORECAST_DAYS=5

# License Configuration
LICENSE_SERVER_URL=
CODECANYON_TOKEN=
CODECANYON_PRODUCT_ID=
LICENSE_ENFORCEMENT_ENABLED=True
LICENSE_OFFLINE_GRACE_HOURS=72
LICENSE_CACHE_TTL_SECONDS=900
LICENSE_SERVER_TIMEOUT_SECONDS=8

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
USE_REDIS_CACHE=True
REDIS_CACHE_URL=redis://redis:6379/1

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Channel Layers (Django Channels)
CHANNEL_LAYERS_BACKEND=redis

# Port Mappings (for docker-compose)
BACKEND_PORT=8000
# Dev (docker-compose.yml): host port published to Vite :5173 — use FRONTEND_HOST_PORT (avoid FRONTEND_PORT; some hosts set it to 80 and break Traefik)
FRONTEND_HOST_PORT=5173
# Prod (docker-compose.prod.yml): host port → Nginx :80 inside container. Default 8080 so Dokploy/Traefik can keep :80
HTTP_PORT=8080
# Vite dev in Docker: Traefik serves https:// — HMR must use wss on 443 (Mixed Content if ws:5173).
# docker-compose defaults VITE_TRAEFIK_HTTPS=1 for the frontend service. For local docker + http://localhost:5173 set:
# VITE_TRAEFIK_HTTPS=0
# Or explicitly: VITE_HMR_PROTOCOL=wss and VITE_HMR_CLIENT_PORT=443
DB_PORT=5432
REDIS_PORT=6379

# Optional: AWS S3 Configuration (if using S3 storage)
# USE_S3_STORAGE=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=pixelcast-signage-content
# AWS_S3_REGION_NAME=us-east-1

# Optional: Email Configuration
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=no-reply@pixelcastsignage.com

# Optional: Notification Encryption Key
# NOTIFICATION_ENCRYPTION_KEY=

# Optional: Backup Configuration
# BACKUP_DIR=/app/backups
# BACKUP_RETENTION_DAYS=30
# ENABLE_AUTO_BACKUP=False
# BACKUP_ENCRYPTION=False

# Optional: Rate Limiting
# RATE_LIMITING_ENABLED=True
# MAX_LOGIN_ATTEMPTS=5
# LOCKOUT_DURATION=900

# Optional: Audit Logging
# AUDIT_LOGGING_ENABLED=True
# AUDIT_LOG_READS=False
# AUDIT_RETENTION_DAYS=365

