# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend

# Database Configuration
DB_NAME=screengram_db
DB_USER=screengram_user
DB_PASSWORD=your-secure-password-here
DB_HOST=db
DB_PORT=5432
USE_SQLITE=False

# Application URLs
BASE_URL=http://localhost:8000

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
USE_REDIS_CACHE=True
REDIS_CACHE_URL=redis://redis:6379/1

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Channel Layers (Django Channels)
CHANNEL_LAYERS_BACKEND=redis

# Port Mappings (for docker-compose)
BACKEND_PORT=8000
FRONTEND_PORT=80
DB_PORT=5432
REDIS_PORT=6379

# Optional: AWS S3 Configuration (if using S3 storage)
# USE_S3_STORAGE=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=screengram-content
# AWS_S3_REGION_NAME=us-east-1

# Optional: Email Configuration
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=no-reply@screengram.com

# Optional: Notification Encryption Key
# NOTIFICATION_ENCRYPTION_KEY=

# Optional: Backup Configuration
# BACKUP_DIR=/app/backups
# BACKUP_RETENTION_DAYS=30
# ENABLE_AUTO_BACKUP=False
# BACKUP_ENCRYPTION=False

# Optional: Rate Limiting
# RATE_LIMITING_ENABLED=True
# MAX_LOGIN_ATTEMPTS=5
# LOCKOUT_DURATION=900

# Optional: Audit Logging
# AUDIT_LOGGING_ENABLED=True
# AUDIT_LOG_READS=False
# AUDIT_RETENTION_DAYS=365

